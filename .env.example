"""
Place this in your project top-level directory alongside rxconfig.py
Copy this .env.example file to .env and fill in the values below.

These values are located at...
Open Supabase Project >> Project Settings >> Data API
"""

api_url="your-api-url"

# Legacy API keys (pre-Oct 2025 projects)
api_key="your-anon-key"
jwt_secret="your-jwt-secret"
service_role="your-service-role"

# New API keys (Oct 2025+ projects — sb_publishable_* / sb_secret_* format)
# api_key="sb_publishable_..."
# secret_api_key="sb_secret_..."